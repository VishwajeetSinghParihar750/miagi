{
  "name": "@miagi/extension",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": ["onCommand:miagi.runAgent", "onCommand:miagi.logEditorContext"],
  "contributes": {
    "configuration": {
      "title": "Miagi",
      "properties": {
        "miagi.llmBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8080/v1",
          "description": "OpenAI-compatible LLM API base URL (must end with /v1)."
        },
        "miagi.llmApiKey": {
          "type": "string",
          "default": "dummy",
          "description": "API key sent to the LLM server."
        },
        "miagi.llmModel": {
          "type": "string",
          "default": "Qwen/Qwen2.5-Coder-1.5B-Instruct-GGUF:Q4_K_M",
          "description": "Model name passed to chat completions."
        },
        "miagi.llmMaxTokens": {
          "type": "number",
          "default": 512,
          "description": "Max tokens per LLM response."
        },
        "miagi.applyLlmBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8081/v1",
          "description": "OpenAI-compatible API base URL for the apply/merge model."
        },
        "miagi.applyLlmApiKey": {
          "type": "string",
          "default": "dummy",
          "description": "API key sent to the apply model server."
        },
        "miagi.applyLlmModel": {
          "type": "string",
          "default": "continuous-lab/FastEdit",
          "description": "Model that merges lazy code_edit snippets into original code (FastEdit 1.7B)."
        },
        "miagi.applyLlmMaxTokens": {
          "type": "number",
          "default": 1024,
          "description": "Max tokens for apply model responses."
        }
      }
    },
    "commands": [
      {
        "command": "miagi.runAgent",
        "title": "Miagi: Run Agent"
      },
      {
        "command": "miagi.logEditorContext",
        "title": "Miagi: Log Editor Context"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --sourcemap",
    "check-types": "tsc -p tsconfig.json --noEmit && tsc -p src/playwright/tsconfig.json --noEmit",
    "dev": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --sourcemap --watch",
    "playwright:dev": "bun run --watch src/playwright/index.ts",
    "playwright:api": "bun run src/playwright/index.ts"
  },
  "dependencies": {
    "openai": "^6.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.19",
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "typescript": "5.9.2"
  }
}
