{
  "name": "miagi",
  "displayName": "Miagi",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": ["onCommand:miagi.fastEdit"],
  "contributes": {
    "commands": [
      {
        "command": "miagi.fastEdit",
        "title": "Miagi: FastEdit"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --watch"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "typescript": "5.9.2"
  }
}
