# llama.cpp server (OpenAI-compatible)
LLM_BASE_URL=http://127.0.0.1:8080/v1
LLM_API_KEY=dummy
LLM_MODEL=Qwen/Qwen2.5-Coder-3B-Instruct-GGUF:Q4_K_M
LLM_MAX_TOKENS=512
LLM_STREAM=true

# Apply model (FastEdit 1.7B) — merges lazy code_edit snippets into original code
APPLY_LLM_BASE_URL=http://127.0.0.1:8081/v1
APPLY_LLM_API_KEY=dummy
APPLY_LLM_MODEL=continuous-lab/FastEdit:gguf/fastedit-1.7b-Q8_0.gguf
APPLY_LLM_MAX_TOKENS=1024

# Used by scripts/fastedit-serve.sh
APPLY_LLM_HF_REPO=continuous-lab/FastEdit
APPLY_LLM_HF_FILE=gguf/fastedit-1.7b-Q8_0.gguf
APPLY_LLM_CTX_SIZE=2048
APPLY_LLM_HOST=127.0.0.1
APPLY_LLM_PORT=8081

# Used by scripts/llama-serve.sh
LLM_HF_REPO=Qwen/Qwen2.5-Coder-3B-Instruct-GGUF:Q4_K_M
LLM_FIT_TARGET_MB=256
LLM_FIT_CTX=2048
LLM_CTX_SIZE=2048
LLM_THREADS=8
LLM_HOST=127.0.0.1
LLM_PORT=8080
