{
  "name": "miagi",
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.4",
    "typescript": "5.9.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "serve:llama": "bun run --cwd apps/backend serve:llama",
    "serve:fastedit": "bun run --cwd apps/backend serve:fastedit",
    "playwright:api": "bun run --cwd apps/extension playwright:api",
    "playwright:dev": "bun run --cwd apps/extension playwright:dev"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
